# Optional: override the backend base URL.
#
# Local dev default: http://localhost:8081/api (or 8080 if you mapped Docker to 8080)
# Production default: /api (same-origin)
#
# IMPORTANT for Vercel: set this to your hosted Spring Boot backend URL,
# otherwise the deployed frontend will not be able to create/read/update/delete.
# Example:
# REACT_APP_API_BASE_URL=https://your-backend-host.com/api
REACT_APP_API_BASE_URL=
